{
  "manifest_version": 3,
  "name": "Clinical Memory Bridge",
  "version": "0.1.0",
  "description": "Bring an existing ChatGPT tab/window to the front for the Clinical Memory Assistant.",
  "permissions": ["tabs", "windows"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://willow-baek.github.io/clinical-memory-assistant/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "file:///*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Clinical Memory Bridge"
  }
}
